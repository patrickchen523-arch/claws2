  <diagram id="p6_pact" name="惩罚契约系统">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p6_bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1920" height="1080" as="geometry"/>
        </mxCell>
        <mxCell id="p6_tl" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0170C1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="20" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p6_tr" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0170C1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="0" width="1880" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p6_title" value="04 核心机制 - 惩罚契约系统" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=36;fontColor=#0170C1;fontFamily=方正尚酷简体;" vertex="1" parent="1">
          <mxGeometry x="120" y="80" width="800" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p6_en" value="PACT OF PUNISHMENT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontColor=#000000;fontFamily=Garage Gothic;" vertex="1" parent="1">
          <mxGeometry x="120" y="150" width="500" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p6_desc" value="一句话解释：&#xa;就像给自己加&quot;debuff&quot;换奖励——签订契约给自己增加各种惩罚&#xa;难度越高给的稀有资源越多" style="text;html=1;strokeColor=#FF9500;fillColor=#FFF8E8;align=left;verticalAlign=middle;fontSize=22;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="120" y="220" width="800" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="p6_box1" value="&#xa;  热度等级&#xa;  0-64，可叠加多个修改器&#xa;  数值越高难度越大" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="120" y="380" width="350" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="p6_box2" value="&#xa;  修改器类型&#xa;  敌人血量/伤害增加&#xa;  祝福获取减少/房间敌人增多" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="520" y="380" width="350" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="p6_box3" value="&#xa;  奖励机制&#xa;  难度越高，通关后&#xa;  &quot;黑暗&quot;&quot;泰坦之血&quot;越多" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="920" y="380" width="350" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="p6_goal" value="&#xa;  解决痛点&#xa;  通关后&quot;没事干&quot;——高难度提供持续挑战目标&#xa;  &quot;高风险高回报&quot;的永恒驱动力" style="text;html=1;strokeColor=#27AE60;fillColor=#E8F8F0;align=left;verticalAlign=middle;fontSize=20;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
