          <mxGeometry x="0" y="0" width="1920" height="1080" as="geometry"/>
        </mxCell>
        <mxCell id="p4_tl" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0170C1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="20" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p4_tr" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0170C1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="0" width="1880" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p4_title" value="02 核心机制 - 神明祝福系统" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=36;fontColor=#0170C1;fontFamily=方正尚酷简体;" vertex="1" parent="1">
          <mxGeometry x="120" y="80" width="800" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p4_en" value="BLESSING SYSTEM" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontColor=#000000;fontFamily=Garage Gothic;" vertex="1" parent="1">
          <mxGeometry x="120" y="150" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p4_desc" value="一句话解释：&#xa;就像抽卡组卡组——每打完一轮怪从3张&quot;神卡&quot;里选一张&#xa;10个神仙各有绝活，组合起来能玩出上百种套路" style="text;html=1;strokeColor=#FF9500;fillColor=#FFF8E8;align=left;verticalAlign=middle;fontSize=22;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="120" y="220" width="800" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="p4_point1" value="&#xa;  随机祝福选择&#xa;  10位希腊神明，每位10+祝福&#xa;  传奇祝福/双重祝福/祝福升级" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="120" y="380" width="350" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="p4_point2" value="&#xa;  树状技能解锁&#xa;  Build基于基础操作&#xa;  需要先解锁A+B才能解锁C&#xa;  提供明确的中长期目标" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="520" y="380" width="350" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="p4_point3" value="&#xa;  策略深度&#xa;  思考祝福组合效果&#xa;  规划解锁路径&#xa;  成就构建满足感" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="920" y="380" width="350" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="p4_bot" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0170C1;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="1050" width="1920" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p5_narrative" name="死亡叙事融合">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
