        </mxCell>
        <mxCell id="p5_title" value="03 核心机制 - 死亡叙事融合" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=36;fontColor=#0170C1;fontFamily=方正尚酷简体;" vertex="1" parent="1">
          <mxGeometry x="120" y="80" width="800" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p5_en" value="DEATH NARRATIVE FUSION" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontColor=#000000;fontFamily=Garage Gothic;" vertex="1" parent="1">
          <mxGeometry x="120" y="150" width="500" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p5_desc" value="一句话解释：&#xa;就像死了还能听故事——每次&quot;死掉&quot;不是结束&#xa;而是回到老家和NPC聊聊天，推进剧情还能变强" style="text;html=1;strokeColor=#FF9500;fillColor=#FFF8E8;align=left;verticalAlign=middle;fontSize=22;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="120" y="220" width="800" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="p5_box1" value="&#xa;  死亡 = 回家&#xa;  玩家被击败后回到&#xa;  &quot;冥王圣殿&quot;" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="120" y="380" width="350" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="p5_box2" value="&#xa;  叙事推进&#xa;  与NPC对话解锁&#xa;  亲情/友情/爱情线" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="520" y="380" width="350" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="p5_box3" value="&#xa;  死亡积累&#xa;  保留&quot;黑暗&quot;&quot;钥匙&quot;&#xa;  货币用于成长" style="text;html=1;strokeColor=#0170C1;fillColor=#F5F9FF;align=left;verticalAlign=middle;fontSize=18;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="920" y="380" width="350" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="p5_problem" value="&#xa;  解决痛点&#xa;  传统Roguelike死亡带来挫败感&#xa;  死亡成为玩家最期待的时刻" style="text;html=1;strokeColor=#E74C3C;fillColor=#FEF0EF;align=left;verticalAlign=middle;fontSize=20;fontColor=#333333;fontFamily=冬青黑体简体中文 W3;rounded=0;" vertex="1" parent="1">
